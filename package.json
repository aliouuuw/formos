{
  "name": "formos",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "bun --bun vite dev --port 3000",
    "generate-routes": "tsr generate",
    "build": "bun --bun vite build",
    "preview": "bun --bun vite preview",
    "start": "bun run .output/server/index.mjs",
    "test": "vitest run",
    "inngest:dev": "bunx inngest-cli@latest dev -u http://localhost:3000/api/inngest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:migrate:local": "DATABASE_URL=postgresql://formos:formos@localhost:5432/formos drizzle-kit migrate",
    "db:migrate:neon": "dotenv -e .env.neon -- drizzle-kit migrate",
    "db:baseline": "bun run scripts/baseline-migrations.ts",
    "db:baseline:local": "DATABASE_URL=postgresql://formos:formos@localhost:5432/formos bun run scripts/baseline-migrations.ts",
    "db:baseline:neon": "dotenv -e .env.neon -- bun run scripts/baseline-migrations.ts",
    "db:push": "drizzle-kit push",
    "db:pull": "drizzle-kit pull",
    "db:studio": "drizzle-kit studio",
    "db:seed": "bun run scripts/seed.ts",
    "db:seed:ipo": "SEED_DEMO_FORM=false bun run scripts/seed.ts",
    "ipo:guide-pdf": "bun run scripts/generate-ipo-guide-pdf.ts",
    "embed-bulletin": "bun run scripts/embed-bulletin-template.ts"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@neondatabase/serverless": "^1.0.2",
    "@orpc/client": "^1.13.6",
    "@orpc/json-schema": "^1.13.6",
    "@orpc/openapi": "^1.13.6",
    "@orpc/server": "^1.13.6",
    "@orpc/tanstack-query": "^1.13.6",
    "@orpc/zod": "^1.13.6",
    "@t3-oss/env-core": "^0.13.10",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-devtools": "latest",
    "@tanstack/react-query": "latest",
    "@tanstack/react-query-devtools": "latest",
    "@tanstack/react-router": "latest",
    "@tanstack/react-router-devtools": "latest",
    "@tanstack/react-router-ssr-query": "latest",
    "@tanstack/react-start": "latest",
    "@tanstack/router-plugin": "^1.132.0",
    "better-auth": "^1.5.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-kit": "^0.31.9",
    "drizzle-orm": "^0.45.1",
    "inngest": "^4.5.1",
    "lucide-react": "^0.577.0",
    "nitro": "npm:nitro-nightly@latest",
    "pg": "^8.16.3",
    "radix-ui": "^1.5.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.0.2",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.3.6",
    "vite-plugin-neon-new": "^0.8.0",
    "zod": "^4.3.6",
    "pdf-lib": "^1.17.1"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.16",
    "@tanstack/devtools-vite": "latest",
    "@tanstack/router-cli": "^1.132.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.10.2",
    "@types/pg": "^8.15.6",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "dotenv": "^17.3.1",
    "dotenv-cli": "^11.0.0",
    "jsdom": "^28.1.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.0",
    "vitest": "^4.1.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ]
  }
}
