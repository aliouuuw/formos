# Database
# Local Docker Postgres (default): docker compose up -d postgres
DATABASE_URL=postgresql://formos:formos@localhost:5432/formos
DATABASE_URL_POOLER=

# Neon Local (optional): docker compose --profile neon up -d neon-local
# NEON_API_KEY=
# NEON_PROJECT_ID=
# PARENT_BRANCH_ID=

# Auth
BETTER_AUTH_SECRET=replace-with-openssl-rand-base64-32-output
BETTER_AUTH_URL=http://localhost:3000

# Restrict admin sign-in to a company email domain (optional)
# ALLOWED_EMAIL_DOMAIN=everestfinance.com

# Inngest (optional in local dev; use `bun run inngest:dev`)
# INNGEST_EVENT_KEY=
# Required in production — verifies requests to /api/inngest
# INNGEST_SIGNING_KEY=

VITE_APP_NAME=Formos

# Legacy slug redirect TTL after a published form slug changes (days). 0 = never expire.
# SLUG_REDIRECT_TTL_DAYS=90
# VITE_SLUG_REDIRECT_TTL_DAYS=90
