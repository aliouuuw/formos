# Database
# Local Docker Postgres (default): docker compose up -d postgres
DATABASE_URL=postgresql://formos:formos@localhost:5432/formos
DATABASE_URL_POOLER=

# Neon (use pooler host + verify-full to avoid pg SSL deprecation warnings)
# DATABASE_URL=postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=verify-full
# NEON_API_KEY=
# NEON_PROJECT_ID=
# PARENT_BRANCH_ID=

# Auth
BETTER_AUTH_SECRET=replace-with-openssl-rand-base64-32-output
BETTER_AUTH_URL=http://localhost:3000

# Seed (bun run db:seed) — sign-up is disabled in the app
# SEED_ADMIN_EMAIL=admin@everestfinance.com
# SEED_ADMIN_PASSWORD=choose-a-strong-password
# SEED_ADMIN_NAME=Formos Admin
# SEED_DEMO_FORM=false
# SEED_DEMO_FORM_SLUG=demo-contact
# SEED_IPO_CAMPAIGN=true

# Restrict admin sign-in to a company email domain (optional)
# ALLOWED_EMAIL_DOMAIN=everestfinance.com

# Inngest (optional in local dev; use `bun run inngest:dev`)
# INNGEST_EVENT_KEY=
# Required for /api/inngest in production (does not block app boot if unset)
# INNGEST_SIGNING_KEY=

VITE_APP_NAME=Formos

# --- Vercel (Project Settings → Environment Variables) ---
# Required in Production:
#   DATABASE_URL          Neon pooler URL (sslmode=verify-full)
#   BETTER_AUTH_SECRET    openssl rand -base64 32
# Optional on Vercel (auto from VERCEL_URL if unset):
#   BETTER_AUTH_URL       https://your-production-domain.com
# Required only if using Inngest jobs:
#   INNGEST_SIGNING_KEY   from Inngest dashboard
#   INNGEST_EVENT_KEY     from Inngest dashboard

# Legacy slug redirect TTL after a published form slug changes (days). 0 = never expire.
# SLUG_REDIRECT_TTL_DAYS=90
# VITE_SLUG_REDIRECT_TTL_DAYS=90
