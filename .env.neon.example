# Neon database — used by `bun run db:migrate:neon` (and other db:*:neon scripts).
# Copy to .env.neon and fill in from Neon dashboard or `neonctl connection-string`.
#
# Use the pooler host + verify-full to avoid pg SSL deprecation warnings.
DATABASE_URL=postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=verify-full

# Optional — only needed for `docker compose --profile neon up` (neon-local proxy)
# NEON_API_KEY=
# NEON_PROJECT_ID=
# PARENT_BRANCH_ID=
